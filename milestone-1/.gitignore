# -------------------------------
# Ignore full datasets
# -------------------------------
PCB_DATASET/
datasets/
data/
*.zip

# Allow only small sample images if needed
!PCB_DATASET/PCB_DATASET/processed/
!PCB_DATASET/PCB_DATASET/processed/samples/
!PCB_DATASET/PCB_DATASET/processed/samples/*

# -------------------------------
# Python cache files
# -------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# -------------------------------
# Google Colab / Jupyter
# -------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
.conda/
cache/
*.log

# -------------------------------
# Model weights / training outputs
# -------------------------------
*.h5
*.pt
*.pth
*.onnx
checkpoints/
models/
outputs/
runs/

# -------------------------------
# Temporary image outputs
# -------------------------------
processed/

# -------------------------------
# OS-generated files
# -------------------------------
.DS_Store
Thumbs.db

# -------------------------------
# Environment files
# -------------------------------
env/
venv/
.venv/
*.swp
*.tmp
